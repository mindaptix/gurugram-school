        <script type="text/javascript">

            function sendEnquiryEvent(state, school, std, stuid) {
                //alert("test");               

                //var s = "";
                //console.log($("#enquiryForm"));
                //$("#txtCaptcha")
                //console.log($(s).offset().top);
                //console.log($("yellowband").outerHeight(!0));
                var t = ($("#enquiryForm").offset().top + $('#enquiryForm').outerHeight() + 100);
                $("html,body").animate({
                    scrollTop: t
                })

                window.dataLayer.push({
                    'event': 'event dl send enquiry submit',
                    'eventCategory': 'enquiry form',
                    'eventAction': 'successful submit',
                    'eventLabel': state + '-' + school + '-' + std,  // dynamic values <> based on user selection of form fields
                    'cd-leadid': stuid // this value of lead id should be same as the one getting sent to backend lms
                });
            }

            function scrollToShortEnquiry() {

                var t = ($("#enquiryForm").offset().top + $('#enquiryForm').outerHeight() + 100);

                $("html,body").animate({
                    scrollTop: t
                })
            }
        </script>
        <!-- Google Script end ---->
