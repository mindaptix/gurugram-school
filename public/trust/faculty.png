    <!-- lifeatpodar start -->
    
<section class="life_at_podar">
 <div class="container text-center">
        <div class="title_purple_30px text-center">A Glimpse into a Student’s Journey at Podar</div>
        <div class="description text-center d-none">A Podar School Adapts To Become</div>
        <div class="cardsBox d-flex justify-content-around life_at_podar slick-slider">


         <div>
            <div class="card"><img src="../../assets/images/student life/integrated-learning-program.webp" alt="podar education integrated learning program - creativity and social responsibility" />
              <div class="card-body text-start">
                <h5 class="card-title">Integrated Learning Program </h5>
                <p class="card-text">Theme-based, hands-on modules connecting subjects to real-world issues, building critical thinking, creativity, collaboration, research, and social responsibility.</p>
              </div>
            </div>
          </div>
          
          <div>
            <div class="card"><img src="../../assets/images/student life/digital-skills-and-coding.webp" alt="podar education school students performing digital skills and coding" />
              <div class="card-body text-start">
                <h5 class="card-title">Digital Skills & Coding</h5>
                <p class="card-text">Coding starts in preschool, progressing from playful blocks to advanced programming, robotics, AI, and app development—building creativity, logic, and future-ready digital skills.</p>
              </div>
            </div>
          </div>


          <div>
            <div class="card"><img src="../../assets/images/student life/innovation-lab.webp" alt="podar education innovation lab - focusing on creativity and technological exploration." />
              <div class="card-body text-start">
                <h5 class="card-title">Innovation Labs</h5>
                <p class="card-text">Hands-on STEM playground with robotics, electronics, engineering, and coding, encouraging design thinking, problem-solving, teamwork, and innovation through exciting real-world projects.</p>
              </div>
            </div>
          </div>


          <div>
            <div class="card"><img src="../../assets/images/student life/remedial-learning.webp" alt="students engaging in remedial learning at podar education school" />
              <div class="card-body text-start">
                <h5 class="card-title">Remedial Learning</h5>
                <p class="card-text">Personalised support to bridge learning gaps, reinforce foundations, and build student confidence, ensuring every child keeps pace and thrives academically.</p>
              </div>
            </div>
          </div>

          <div>
            <div class="card"><img src="../../assets/images/student life/symphonics.webp" alt="podar education school students performing in a symphonics music program" />
              <div class="card-body text-start">
                <h5 class="card-title">Symphonics</h5>
                <p class="card-text">Phonics-based English foundation program using stories and multi-sensory learning to build early literacy, vocabulary, writing, and confident communication skills. Pre-school to Grade 2.</p>
              </div>
            </div>
          </div>

          <div>
            <div class="card"><img src="../../assets/images/student life/podar-model-united-nations.webp" alt="podar education school students debate global issues while developing international awareness" />
              <div class="card-body text-start">
                <h5 class="card-title">Podar Model United Nations</h5>
                <p class="card-text">Annual UN simulation where students debate global issues, fostering leadership, diplomacy, research, teamwork, and public speaking while developing international awareness.</p>
              </div>
            </div>
          </div>



          

          


        </div><a class="btn" href="/the-right-students-life">ENTER THE STUDENTS JOURNEY</a>
      </div>     
</section>
    <!-- lifeatpodar End -->
    <!--PodarInitiatives start -->
    <section class='latest_news' style='background: transparent linear-gradient(275deg, rgba(131, 41, 150, 0.1098039216) 0%, rgba(220, 118, 3, 0.1294117647) 100% ) 0% 0% no-repeat padding-box;'><div class='container text-center d-flex flex-column'><div class='title_purple_30px text-center'>Podar Initiatives</div><div class='cardsBox d-flex justify-content-around latestNews slick-slider' ><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2023-9-10--16-27-56-377_podar-internatonal-schools.webp' alt='Podar International School' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Podar International School</h5><p class='card-text'>Schools (from Nursery to Grade 12) operated and managed completely by Podar Education Network.</p><a class='link-text' href='https://www.podareducation.org/locations'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2023-8-25--17-39-55-203_podar-initiatives-podar-smarter-schools.webp' alt='Podar Smarter Schools' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Podar Smarter School</h5><p class='card-text'>Complete all-round assistance to partners in starting a school or upgrading their existing school.</p><a class='link-text' href='https://www.podarsmarterschools.com/'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2020-11-5--16-8-35-753_podarjumbokids.webp' alt='Podar Prep Schools in India' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Podar Prep</h5><p class='card-text'>The renowned Preschool Brand of Podar Education Network delivering Quality Education from Playgroup (Age 2) to Senior Kg (Age 5).</p><a class='link-text' href='https://podarprep.com/'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2020-11-5--16-11-31-367_bornsmart.webp' alt='Podar International School Mother Toddlers Program' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Born Smart</h5><p class='card-text'>A premier Mother Toddler program for children aged 0-3 years. Born Smart is a collection of age appropriate activities for new parents.</p><a class='link-text' href='http://www.born-smart.com/'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2020-11-5--16-8-57-156_podarworldcollege.webp' alt='Podar World College ' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Podar World College</h5><p class='card-text'>Students can obtain a prestigious Undergraduate or Graduate degree from the University of London or the University of Wolverhampton while studying in India. </p><a class='link-text' href='http://www.podarworldcollege.org/'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2020-11-5--16-9-18-413_podarinstituteofeducation.webp' alt='Podar Teacher Training Institute Education' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Podar Institute of Education</h5><p class='card-text'>The award winning Teacher Training Institute managed by Podar Education Network. Courses include ECCED and CACHE.</p><a class='link-text' href='http://www.podarinstitute.com/'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div><div><div class='card' style='background: #ffffff; border: 1px solid #efefef; align-items: stretch; height: 520px;'><img src='/Uploads/Venture/2020-11-5--16-8-6-195_podarsmarttours.webp' alt='Podar International School Smart Tours' height='350px' style='object-fit: cover; border-radius: 10px;'><div class='card-body text-start d-flex flex-column justify-content-between'><h5>Smart Tours</h5><p class='card-text'>Broadening young minds through safe, educative and well-curated student tours.</p><a class='link-text' href='http://smart-tours.org/'>Read More <span class='custom-icon cust-ico-download mr-1'><img src='../assets/images/icons/icon-orange-arrow.png' alt='arrow icon' /></span></a></div></div></div> </div> </div></section>
    <!--PodarInitiatives End -->


