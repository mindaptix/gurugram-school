    <script type="text/javascript">

        const validateEmail = (email) => {
            return email.match(
                /^(([^<>()[\]\\.,;:\s@\"]+(\.[^<>()[\]\\.,;:\s@\"]+)*)|(\".+\"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
            );
        };

        function validate() {


            var stateID = "ddlstate2";
            if (document.getElementById(stateID).selectedIndex == "0") {
                document.getElementById(stateID).focus();
                alert("Please select State.");
                return false;
            }

            var ctyID = "ddlcity2";
            if (document.getElementById(ctyID).selectedIndex == "0") {
                document.getElementById(ctyID).focus();
                alert("Please select City.");
                return false;
            }

            var schID = "ddlSchool1";
            if (document.getElementById(schID).selectedIndex == "0") {
                document.getElementById(schID).focus();
                alert("Please select a School.");
                return false;
            }

            var txtName = "txtName";
            if (document.getElementById(txtName).value == "") {
                document.getElementById(txtName).focus();
                alert("Please Enter First Name");
                return false;
            }

            var txtLName = "txtlastname1";
            if (document.getElementById(txtLName).value == "") {
                document.getElementById(txtLName).focus();
                alert("Please Enter Last Name");
                return false;
            }

            var standardID = "ddlStandard1";
            if (document.getElementById(standardID).selectedIndex == "0") {
                document.getElementById(standardID).focus();
                alert("Please select standard.");
                return false;
            }

            var email = "txtEmail1";
            if (document.getElementById(email).value == "") {
                document.getElementById(email).focus();
                alert("Please Enter Email ID");
                return false;
            }
            else {
                if (!validateEmail(document.getElementById(email).value)) {
                    document.getElementById(email).focus();
                    alert("Please Enter Proper Email ID");
                    return false;
                }
            }

            var txtPhoneNo = "txtPhoneNo";
            if (document.getElementById(txtPhoneNo).value == "") {
                document.getElementById(txtPhoneNo).focus();
                alert("Please Enter contact number");
                return false;
            }
            else {
                if ($("#txtPhoneNo").val().length != 10) {
                    document.getElementById(txtPhoneNo).focus();
                    alert("Please Enter 10 Digit Mobile number");
                    return false;
                }

            }

            var txtCaptcha = "txtCaptcha";
            if (document.getElementById(txtCaptcha).value == "") {
                document.getElementById(txtCaptcha).focus();
                alert("Please Enter Captcha");
                return false;
            }

            var captchavalue = $("#txtCaptcha").val();
            var captcharesult = false;
            $.ajax({
                async: false,
                type: "POST",
                url: "/ImageVerify.aspx/verifycaptchaForShortEnquriy",
                data: "{ captchavalue:'" + captchavalue + "'}",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    if (data.d == "false") {
                        captcharesult = false;
                    }
                    else {
                        captcharesult = true;
                    }

                },
                failure: function (response) {
                    alert('There was an error.');
                    return false;
                }
            });


            if (captcharesult == false) {
                document.getElementById(txtCaptcha).focus();
                alert("Invalid Verification Code!");
                return false;
            }


            var var1 = document.getElementById('ctl00_ddlstate2').selectedOptions[0].innerHTML + "|" + document.getElementById('ctl00_ddlcity2').selectedOptions[0].innerHTML + "|" + document.getElementById('ctl00_ddlSchool1').selectedOptions[0].innerHTML + "|" + document.getElementById('ctl00_ddlStandard1').selectedOptions[0].innerHTML;

            //alert(var1);
            //alert(document.title);

            window.dataLayer = window.dataLayer || [];
            //window.dataLayer.push({
            //    'event': 'dl - enquire submit',
            //    'cta_location': 'School Admission Process Details - Podar International School',         // this should be replaced with values based on each event
            //    'additional_info': var1,         // this should be replaced with values based on each event
            //    'school_location': ''         // this should be replaced with values based on each event
            //});

            dataLayer.push({
                'event': 'lead_submission',
                'enhanced_conversion_data': {
                    "email": document.getElementById(email).value, /* Change yourEmailVariable to the datalayer variable name where you are storing the user’s email data. Do the same for the other variables below. Make sure the values aren't hashed. */
                    "phone_number": document.getElementById(txtPhoneNo).value /* Phone Number must be collected in the E.164 format, which means it must be 11 to 15 digits including a plus sign (+) prefix and country code with no dashes, parentheses, or spaces. Example: ‘+11231234567’ */
                }
            });



            return true;
        }

        function validatestate2(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('ddlstate2').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('ddlstate2').style.borderColor = "#bebebe";
            }
        }

        function validateSchool1(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('ddlSchool1').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('ddlSchool1').style.borderColor = "#bebebe";
            }
        }

        function validateffname1(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('txtffname1').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('txtffname1').style.borderColor = "#bebebe";
            }
        }

        function validatelname1(source, args) {
            //            alert(args.Value);
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('txtlastname1').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('txtlastname1').style.borderColor = "#bebebe";
            }
        }

        function validategender1(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('drpgender1').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('drpgender1').style.borderColor = "#bebebe";
            }
        }

        function validatestandard1(source, args) {
            if ((args.Value == "") || (args.Value == "0")) {
                args.IsValid = false;
                document.getElementById('ddlStandard1').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('ddlStandard1').style.borderColor = "#bebebe";
            }
        }
        function validatestream1(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('ddlStream1').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('ddlStream1').style.borderColor = "#bebebe";
            }
        }
        function validatePhoneNo(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('txtPhoneNo').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('txtPhoneNo').style.borderColor = "#bebebe";
            }

        }

        function validateName(source, args) {
            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('txtName').style.borderColor = "#EE2D35";
            }
            else {
                args.IsValid = true;
                document.getElementById('txtName').style.borderColor = "#bebebe";
            }
        }

        function validateEmail1(source, args) {

            if (args.Value == "") {
                args.IsValid = false;
                document.getElementById('txtEmail1').style.borderColor = "#EE2D35";
            }
            else {
                //                alert(args.Value);
                var x = args.Value;
                var atpos = x.indexOf("@");
                var dotpos = x.lastIndexOf(".");
                if (atpos < 1 || dotpos < atpos + 2 || dotpos + 2 >= x.length) {
                    args.IsValid = false;
                    document.getElementById('txtEmail1').style.borderColor = "#EE2D35";
                    document.getElementById('RequiredFieldValidator26').style.display = "none";

                }
                else {
                    args.IsValid = true;
                    document.getElementById('txtEmail1').style.borderColor = "#bebebe";
                }
            }
        }

        function ISNumeric(event) {
            if (event.charCode >= 48 && event.charCode <= 57) {
            }
            else {
                event.preventDefault();

            }
        }
        function ClearError(controlname) {
            $("#" + controlname + "").text('');
        }

    </script>

    
